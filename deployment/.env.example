# Copy to deployment/.env and fill in values.

# ── ChromaDB ────────────────────────────────────────────────────────────────
CHROMA_AUTH_TOKEN=replace-with-a-long-random-token
CHROMA_COLLECTION_NAME=research_chunks_v1

# ── Embedding (FastEmbed) ─────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RETRIEVAL_TOP_K=4
MAX_CONTEXT_CHARS=12000

# ── Ollama ───────────────────────────────────────────────────────────────
# Model served from your public HF repo (no auth needed — repo is public)
# Pulled automatically by the ollama container on first startup (~2.5 GB).
# Subsequent runs use the cached model in the ollama_data volume.
OLLAMA_MODEL_NAME=qwen3.5-private-analyst
LLAMA_API_URL=http://ollama:11434/v1

# LLM generation params
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=900
LLM_TIMEOUT_SECONDS=120

# ── Optional nginx proxy ──────────────────────────────────────────────────
# Relies on TLS certificates in deployment/certs/
