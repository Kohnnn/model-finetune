# Copy this file to deployment/.env and replace placeholders before startup.

CHROMA_AUTH_TOKEN=replace-with-a-long-random-token
CHROMA_COLLECTION_NAME=research_chunks_v1

EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Higher-quality but much slower CPU option: intfloat/multilingual-e5-large
RETRIEVAL_TOP_K=4
MAX_CONTEXT_CHARS=12000

LLAMA_MODEL_FILENAME=Qwen3.5-4B.Q4_K_M.gguf
LLAMA_MMPROJ_FILENAME=Qwen3.5-4B.BF16-mmproj.gguf
LLAMA_CONTEXT_SIZE=4096
LLM_MODEL_NAME=qwen3.5-private-analyst
LLM_TIMEOUT_SECONDS=120

# Optional nginx profile settings still rely on local cert files in deployment/certs.
